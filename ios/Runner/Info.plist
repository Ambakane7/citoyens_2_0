<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

	<!-- Configuration générale -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>

	<key>CFBundleDisplayName</key>
	<string>CITOYENS 2.0</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<key>CFBundleName</key>
	<string>CITOYENS_2_0</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>

	<key>CFBundleSignature</key>
	<string>????</string>

	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>

	<key>LSRequiresIPhoneOS</key>
	<true/>

	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
	</array>

	<!-- Storyboard -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<!-- Orientations -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Performance -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Chiffrement -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- ========================= -->
	<!-- Permissions -->
	<!-- ========================= -->

	<!-- Caméra -->
	<key>NSCameraUsageDescription</key>
	<string>Citoyens 2.0 utilise l'appareil photo afin de vous permettre de prendre des photos pour accompagner vos signalements.</string>

	<!-- Galerie -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Citoyens 2.0 accède à votre galerie afin de vous permettre de sélectionner des photos pour vos signalements.</string>

	<!-- Sauvegarde des photos (optionnel mais recommandé) -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Citoyens 2.0 peut enregistrer des images dans votre galerie lorsque cela est nécessaire.</string>

	<!-- Localisation -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Citoyens 2.0 utilise votre position afin de localiser précisément les signalements que vous effectuez.</string>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Citoyens 2.0 peut utiliser votre position pour améliorer la précision des signalements.</string>

	<!-- Notifications -->
	<key>NSUserNotificationsUsageDescription</key>
	<string>Citoyens 2.0 vous envoie des notifications pour vous informer du suivi de vos signalements.</string>

</dict>
</plist>